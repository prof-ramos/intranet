## 4. Padrão de Estado Global (Alpine Store)

```javascript
// resources/js/alpine/stores/notification.js
export default () => ({
    notifications: [],
    timeout: null,

    show(message, type = 'info') {
        this.notifications.push({ message, type });

        // Auto-remove após 5 segundos
        setTimeout(() => {
            this.remove(0);
        }, 5000);
    },

    remove(index) {
        this.notifications.splice(index, 1);
    }
});
