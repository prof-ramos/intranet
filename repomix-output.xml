# docs/openapi.yaml
openapi: 3.0.0
info:
  title: Intranet ASOF API
  version: 1.0.0
paths:
  /api/tasks:
    get:
      summary: Lista tarefas
      parameters:
        - name: status
          in: query
          schema:
            type: string
            enum: [todo, progress, review, done]
      responses:
        '200':
          description: Lista paginada
